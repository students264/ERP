<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>payment Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow" style="position:sticky;top:0px;z-index:1;">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">Manage Expences</a>
            <div class="d-flex gap-3">
                <a href="/" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a href="/logout" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </nav>
    <div class="container-fluid mt-3">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h1 class="text-center fs-3 fw-bold text-dark mb-3">Progyan Education</h1>
                    <p class="text-center fs-5 fw-semibold mb-5">Expences</p>
                    <form action="/expence/insert" method="post">
    <div class="row g-2 align-items-end">
        <div class="mb-3">
                <label class="form-label small fw-bold">Date</label>
                <input type="date" name="date" class="form-control" required style="width:400px;">
        </div>
        <div class="mb-3">
            <label class="form-label small fw-bold">Month</label>
            <select name="month" class="form-control" required style="width:400px;">
            <option value="">Month</option>
            <option>January</option>
            <option>February</option>
            <option>March</option>
            <option>April</option>
            <option>May</option>
            <option>June</option>
            <option>July</option>
            <option>August</option>
            <option>September</option>
            <option>October</option>
            <option>November</option>
            <option>December</option>
          </select>
        </div>
        <div class="col">
            <label class="form-label fw-bold">Year</label>
            <input type="number" name="year" class="form-control" required value="<%= new Date().getFullYear() %>">
              </div>
        <div class="col">
            <label class="form-label fw-bold">Pay In</label>
            <input type="text" name="pay" class="form-control" placeholder="Pay in" required>
        </div>
        <div class="col">
            <label class="form-label fw-bold">Mode</label>
            <select name="mode" class="form-select" required onchange="showField(this.value)">
                <option>CASH</option>
                <option>UPI</option>
                <option>NEFT</option>
            </select>
        </div>
        <div class="col">
            <label class="form-label fw-bold">Receiver</label>
            <input type="text" name="receiver" class="form-control" placeholder="Enter Receiver name" required>
        </div>
        <div class="col" id="show" style="display:none;">
            <label class="form-label fw-bold">Reference Number</label>
            <input type="number" name="RN" class="form-control" style="width:300px;">
        </div>
        <div class="col">
            <label class="form-label fw-bold">Amount</label>
            <input type="number" name="amount" class="form-control" placeholder="Enter the Amount" required>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary fw-semibold">
                Add
            </button>
        </div>
    </div>
</form>
                </div>
                <div class="row justify-content-center mb-4 mt-5">
                <div class="col-md-6">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-primary text-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control" placeholder="Search expence...">
                        <button class="btn btn-primary fw-bold" onclick="searchTable()">
                            Search
                        </button>
                        <button class="btn btn-outline-secondary" onclick="resetTable()">
                            Reset
                        </button>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">

                    <thead class="table-primary">
                        <tr>
                            <th>Date</th>
                            <th>Month</th>
                            <th>Year</th>
                            <th>Pay In</th>
                            <th>Mode</th>
                            <th>Receiver</th>
                            <th>Reference Number</th>
                            <th>&#8377 Amount</th>
                            <th>Update</th>
                            <th>Delete</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">
    <% if (!data || data.length === 0) { %>
        <tr>
            <td colspan="6" class="text-muted py-4">
                No records found
            </td>
        </tr>
    <% } %>

    <% data.forEach(function(item) { %>
        <tr>
            <td><%= new Date(item.Date).toLocaleDateString('en-CA') %></td>
            <td><%= item.Month && item.Month.length > 0 ? item.Month[0] : '' %></td>
            <td><%= item.year %></td>
            <td><%= item.Pay %></td>
            <td><%= item.Mode && item.Mode.length > 0 ? item.Mode[0] : '' %></td>
            <td><%= item.Reciept %></td>
            <td><%= item.rn || "--" %></td>
            <td><%= item.Amount %></td>
            <td>
                <a href="/expence/edit/<%= item._id %>" class="btn btn-sm btn-success">
                    Update
                </a>
            </td>
            <td>
                <a href="/expence/delete/<%= item._id %>" class="btn btn-sm btn-danger">
                    Delete
                </a>
            </td>
        </tr>
    <% }) %>
</tbody>

                </table>
            </div>

        </div>
    </div>
    <script>
        function searchTable() {
            let filter = document.getElementById("searchInput").value.toLowerCase();
            let rows = document.querySelectorAll("#tableBody tr");

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        }

        function resetTable() {
            document.getElementById("searchInput").value = "";
            let rows = document.querySelectorAll("#tableBody tr");
            rows.forEach(row => row.style.display = "");
        }
        function showField(value) {
    const show = document.getElementById('show');

    if (value === "UPI" || value === "CHEQUE" || value === "NEFT") {
        show.style.display = "block";
    } else {
        show.style.display = "none";
    }
}
    </script>
            </div>
        </div>
    </div>
    <script>
        function searchTable() {
            let filter = document.getElementById("searchInput").value.toLowerCase();
            let rows = document.querySelectorAll("#tableBody tr");

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        }

        function resetTable() {
            document.getElementById("searchInput").value = "";
            let rows = document.querySelectorAll("#tableBody tr");
            rows.forEach(row => row.style.display = "");
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>