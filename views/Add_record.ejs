<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Record</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">Admission Management</a>

            <div class="d-flex gap-3">
                <a href="/" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a href="/logout" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </nav>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-6 col-md-8">

        <div class="card border border-0">
          <div class="card-header bg-white border-bottom text-center">
            <h5 class="mb-0 fw-semibold">Add student Records</h5>
          </div>
          <div class="card-body">

            <form action="/student/add" method="POST">

              <div class="mb-3">
                <label class="form-label small fw-semibold">Name</label>
                <input type="text" name="name" class="form-control" placeholder="Enter item name" required>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Joining Date</label>
                <input type="date" name="date" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Address</label>
                <input type="text" name="address" class="form-control" placeholder="Enter address" required>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">phone No:</label>
                <input type="text" name="mobile" class="form-control" placeholder="Enter Mobile Number" required>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-semibold">Education type</label>
                <select name="type" id="type" class="form-control" required onchange="update()">
  <option>Course</option>
  <option>Coaching</option>
</select>
              </div>
              <div class="mb-3" style="display:none;" id="one">
                <label class="form-label small fw-semibold">Educational_Service</label>
                <select id="coaching" name="Educational_Service" class="form-control">
                  <option>class iii</option>
                  <option>class iv</option>
                  <option>class v</option>
                  <option>class vi</option>
                  <option>class vii</option>
                  <option>class viii</option>
                  <option>class ix</option>
                  <option>class x</option>
                  <option>class xi</option>
                  <option>class xii</option>
                </select>
              </div>
              <div class="mb-3" id="three" style="display:none;">
                <label class="form-label small fw-semibold">Board:</label>
                  <select id="board" name="board" class="form-control">
                  <option>CBSE</option>
                  <option>ICSE</option>
                  </select>
              </div>
              <div class="mb-3" id="two" style="display:none;">
                <label class="form-label small fw-semibold">Educational_Service</label>
                <select id="course" name="Educational_Service" class="form-control">
                  <option>MS-OFFICE</option>
                  <option>TALLY</option>
                  <option>GST</option>
                  <option>TDS</option>
                  <option>INCOME TAX</option>
                  <option>ADV.EXCEL</option>
                  <option>DTP</option>
                  <option>GRAPHIC DESIGN</option>
                  <option>INTERNET</option>
                  <option>AUDIO & VIDEO EDITING</option>
                  <option>C++</option>
                  <option>JAVA(B)</option>
                  <option>PYTHON</option>
                  <option>HTML</option>
                  <option>Q BASIC</option>
                  <option>GW BASIC</option>
                  <option>SMALL BASIC</option>
                  <option>WEB DESIGN</option>
                  <option>ORACLE</option>
                  <option>WEB DEVELOPMENT</option>
                  <option>ENG. TYPING</option>
                  <option>BENG. TYPING</option>
                  <option>SPOKEN ENGLISH</option>
                  <option>DIGITAL MARKERING</option>
                </select>
              </div>
               <div class="mb-3">
                <label class="form-label small fw-semibold">Month</label>
                <select name="month" class="form-control" required>
                  <option value="">Select Month</option>
                  <option>January</option>
                  <option>February</option>
                  <option>March</option>
                  <option>April</option>
                  <option>May</option>
                  <option>June</option>
                  <option>July</option>
                  <option>August</option>
                  <option>September</option>
                  <option>October</option>
                  <option>November</option>
                  <option>December</option>
                </select>
              </div>
              <div class="d-grid">
                <button type="submit" class="btn btn-primary fw-semibold rounded-pill">
                  Add Record
                </button>
              </div>

            </form>

          </div>
        </div>

      </div>
    </div>
  </div>
  <script>
function update() {

    const type = document.getElementById("type").value;

    const one = document.getElementById("one");
    const two = document.getElementById("two");
    const three = document.getElementById("three");

    const coaching = document.getElementById("coaching");
    const course = document.getElementById("course");
    const board = document.getElementById("board");

    if (type === "Coaching") {

        one.style.display = "block";
        three.style.display = "block";
        two.style.display = "none";

        coaching.disabled = false;
        board.disabled = false;

        course.disabled = true;

    } else {

        one.style.display = "none";
        three.style.display = "none";
        two.style.display = "block";

        coaching.disabled = true;
        board.disabled = true;

        course.disabled = false;
    }
}
update();
</script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>