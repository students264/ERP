<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance Management</title>
     <style>
      .no-focus:focus {
    outline: none;
    box-shadow: none;
    border: none;
    background: none;
}
     </style>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow" style="position:sticky;top:0px;z-index:1;">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                Attendance Management
            </a>

            <div class="d-flex gap-3">
                <a href="/" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a href="/logout" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container my-5">

        <!-- Heading -->
        <div class="card border-0 p-3 mb-3">
            <h1 class="text-center fw-semibold mb-3">
                Progyan Education
            </h1>

            <h5 class="text-center fw-semibold mb-2 mt-4">
                Employee Attendance of
                <%= new Date().toLocaleString('en-US', { month: 'long' }) %>
                <%= new Date().getFullYear() %>
            </h5>
        </div>

        <!-- Table -->
        <div class="card border shadow-sm p-3">

            <% 
            let arr = [
                "Arup Kumar Dhar",
                "Kumarjit Das",
                "Kshitiz Kumar Prasad",
                "Siddhant Jalan",
                "Arnab Ghosh",
                "Tamal Krishna Roy",
                "Anuradha Giri"
            ] 
            %>

            <div class="table-responsive">
                <table class="table table-hover table-bordered text-center">

                    <thead class="table-primary">
                        <tr>
                            <th>Name</th>
                            <th>Date</th>
                            <th>Day</th>
                            <th>Month</th>
                            <th>Status</th>
                            <th>Add</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">

                        <% arr.forEach((name,index) => { %>

                        <tr>
                          <form action="/employee" method="post">
                            <td><input type="text" name="name" value = "<%= name %>" 
              class="mb-2 border-0 text-center no-focus" readonly></td>

                            <td>
                               <input type="date" name="date" class="mb-2 status-field border-0 text-center no-focus"
              value="<%= new Date().toLocaleDateString('en-CA') %>">
                            </td>

                            <td>
            <input type="text" name="day" class="mb-2 border-0 text-center no-focus"
              value="<%= new Date().toLocaleString('en-US', { weekday: 'long' }) %>">
            </td>
                            <td>
                                <input type="text" name="month" class="mb-2 border-0 text-center no-focus"
              value="<%= new Date().toLocaleString('en-US', { month: 'long' }) %>">
                            </td>
                            <td>
  <input type="text" name="status" class="mb-2 status-field border-0 text-center no-focus" readonly>
  <button type="button"
          class="btn btn-sm btn-success attendance-btn rounded-5"
          onclick="setAttendance(this, 'Present')">
    P
  </button>

  <button type="button"
          class="btn btn-sm btn-danger attendance-btn rounded-5"
          onclick="setAttendance(this, 'Absent')">
    A
  </button>
                            </td>
                            <td>
              <button type="submit" class="btn btn-sm btn-primary px-4 mt-2">Add</button>
            </td>
            </form>
                        </tr>
                        <% }) %>

                    </tbody>

                </table>
            </div>

        </div>

    </div>
    <script>
  function setAttendance(button, status) {
    let td = button.parentElement;
    let buttons = td.querySelectorAll(".attendance-btn");
    let statusField = td.querySelector(".status-field");
    buttons.forEach(btn => {
      btn.classList.remove("btn-success", "btn-danger");
      if (btn.innerText.trim() === "Present") {
        btn.classList.add("btn-outline-success");
      } else {
        btn.classList.add("btn-outline-danger");
      }
    });
    if (status === "Present") {
      button.classList.remove("btn-outline-success");
      button.classList.add("btn-success");
    } else {
      button.classList.remove("btn-outline-danger");
      button.classList.add("btn-danger");
    }
    statusField.value = status;
  }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>