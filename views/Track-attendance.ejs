<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">Attendance Management</a>

            <div class="d-flex gap-3">
                <a href="/" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a href="/logout" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </nav>
    <div class="container-fluid mt-3">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h1 class="text-center fs-3 fw-bold text-dark mb-3">Progyan Education</h1>
                    <p class="text-center fs-5 fw-semibold mb-5">Track Attendance</p>
                    <form action="/search" method="get">
    <div class="row g-2 align-items-end">
        <div class="col">
            <label class="form-label fw-bold">Name</label>
            <input type="text" name="name" class="form-control" required style="width:400px;" placeholder="Enter name:">
        </div>
        <div class="col">
            <label class="form-label fw-bold">Category</label>
             <select name="person" class="form-select" required>
                <option>Teacher</option>
                <option>Student</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary fw-semibold">
                Search
            </button>
        </div>

    </div>
</form>
                </div>
                <div class="row justify-content-center mb-4 mt-5">
                    <% if(msg) { %>
                 <p class="text-center fw-bold text-danger fst-italic"><%= msg %></p>
                    <% } %>
               </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">

                    <thead class="table-primary">
                        <tr>
                            <th>Name</th>
                            <th>Date</th>
                            <th>Day</th>
                            <th>Month</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody">
    <% if (!data || data.length === 0) { %>
        <tr>
            <td colspan="6" class="text-muted py-4">
                No records found
            </td>
        </tr>
    <% } %>

    <% data.forEach(function(item) { %>
        <tr>
            <td><%= item.s_name %></td>
            <td><%= new Date(item.Date).toLocaleDateString('en-CA') %></td>
            <td><%= item.Day %></td>
            <td><%= item.Month %></td>
            <td><%= item.Status %></td>
        </tr>
    <% }) %>
</tbody>

                </table>
            </div>

        </div>
    </div>
    <script>
        function searchTable() {
            let filter = document.getElementById("searchInput").value.toLowerCase();
            let rows = document.querySelectorAll("#tableBody tr");

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        }

        function resetTable() {
            document.getElementById("searchInput").value = "";
            let rows = document.querySelectorAll("#tableBody tr");
            rows.forEach(row => row.style.display = "");
        }
    </script>
            </div>
        </div>
    </div>
    <script>
        function searchTable() {
            let filter = document.getElementById("searchInput").value.toLowerCase();
            let rows = document.querySelectorAll("#tableBody tr");

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        }

        function resetTable() {
            document.getElementById("searchInput").value = "";
            let rows = document.querySelectorAll("#tableBody tr");
            rows.forEach(row => row.style.display = "");
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>