<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment Bill</title>
  <style>
    body{
        font-size: 14px;
        padding: 10px;
    }
    table{
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
        word-wrap: break-word;
    }
    th, td{
        border: 1px solid black;
        padding: 6px;
        text-align: center;
        font-size: 12px;
    }
    h1, h2, h3{
        margin: 5px 0;
    }
  </style>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container my-5">
  <div class="p-4">
    <div class="d-flex flex-column justify-content-center align-items-center">
    <% if(msg != ' ') { %>
    <h1 class="text-center text-danger"><%= msg %></h1>
    
    <a href="/" class="btn btn-outline-primary mt-3">
        Back
    </a>
    <% } %>
</div>
  <% if (data && data.length > 0) { %>

    
    <div class="text-center mb-4">
      <h3 class="fw-bold">Progyan Education</h3>
      <p class="text-center fw-bold fs-5 text-danger">Payment Reciept</p>
      <p class="mb-0">
        <strong>Date:</strong>
        <%= data[0].date %>
      </p>
    </div>
    <div class="table-responsive">
      <table class="table table-bordered text-center align-middle">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>M.R Number</th>
            <th>Date</th>
            <th>Month</th>
            <th>Year</th>
            <th>Account</th>
            <th>Payment</th>
            <th>Mode</th>
            <th>Reference Number</th>
            <th>Amount</th>
          </tr>
        </thead>

        <tbody>
          <% data.forEach((item, index) => { %>
            <tr>
              <td><%= item.Name %></td>
              <td><%= item.mr %></td>
              <td><%= item.Date %></td>
              <td><%= item.Month %></td>
              <td><%= item.year %></td>
              <td><%= item.Account %></td>
              <td><%= item.payment %></td>
              <td><%= item.Mode %></td>
              <td><%= item.rn || "--" %></td>
              <td><%= item.Amount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-center gap-3 mt-5">
      <button style="border:none;color:rgb(19, 67, 2);background:none;" onclick="window.location.href='/payment/download-pdf'">
        Download
      </button>

      <button style="border:none; background:none;color:red;" onclick="window.location.href='/'">
        Back
      </button>
    </div>
  <% } %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>