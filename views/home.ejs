<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progyan Education & Classic Computer Training Centre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #e3f2fd, #ffffff);
        }

        .navbar-custom {
            background: linear-gradient(135deg, #0d6efd, #4dabf7);
        }

        .card-custom {
            transition: 0.3s;
        }

        .btn-custom {
            border-radius: 25px;
            padding: 10px 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-custom:hover {
            transform: scale(1.05);
        }

        .section-title {
            font-weight: bold;
            color: #0d6efd;
            letter-spacing: 1px;
        }

        .info-text {
            font-size: 15px;
        }

        .icon-box {
            font-size: 22px;
            margin-right: 8px;
        }
    </style>
</head>

<body>
    <div class="modal fade" id="exampleModal1" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Search</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/payment/check" method="post">
            <label for="id1" class="form-label">Start Date:</label>
            <input type="date" name="date1" id="id1" class="form-control">
            <label for="id2" class="form-label">End Date:</label>
            <input type="date" name="date2" id="id2" class="form-control">
            <div class="d-flex justify-content-center align-items-center mt-3">
                <button type="submit" class="btn btn-primary">Check payment Bill</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="exampleModal2" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Search</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/expence/check" method="post">
            <label for="id1" class="form-label">Start Date:</label>
            <input type="date" name="date1" id="id1" class="form-control">
            <label for="id2" class="form-label">End Date:</label>
            <input type="date" name="date2" id="id2" class="form-control">
            <div class="d-flex justify-content-center align-items-center mt-3">
                <button type="submit" class="btn btn-primary">Check Expence Bill</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>
<div class="navbar-custom text-white py-3 shadow">
    <div class="container d-flex justify-content-between align-items-center">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-mortarboard-fill"></i> Progyan Education
        </h4>
        <a href="/logout" class="btn btn-light btn-sm fw-bold">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>
</div>

<div class="container my-5 border-0">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card card-custom p-4 border-0">
                <div class="row align-items-center">

                    <div class="col-md-6 mb-4 mb-md-0">
                        <h5 class="section-title mb-3">
                            <i class="bi bi-building"></i> Institute Details
                        </h5>

                        <p class="info-text">
                            <i class="bi bi-geo-alt-fill icon-box text-danger"></i>
                            <strong>Address:</strong> 2/80 Dum Dum Road, Kolkata - 700074
                        </p>

                        <p class="info-text">
                            <i class="bi bi-telephone-fill icon-box text-success"></i>
                            <strong>Phone:</strong> +91 9123978181, +91 9007181202
                        </p>

                        <p class="info-text">
                            <i class="bi bi-info-circle-fill icon-box text-primary"></i>
                            Welcome to the admin dashboard of Progyan Education.
                        </p>
                    </div>

                    
                    <div class="col-md-6 text-start">
                        <h5 class="section-title mb-4 text-center">
                            <i class="bi bi-gear-fill"></i> Admin Panel
                        </h5>

                        <div class="row g-3">

    <div class="col-md-6">
        <a href="/admin/admission"
           class="btn btn-outline-primary btn-custom shadow-sm w-100">
           <i class="bi bi-person-plus-fill"></i> Admission
        </a>
    </div>

    <div class="col-md-6">
        <a href="/student/payment"
           class="btn btn-outline-danger btn-custom shadow-sm w-100">
           &#8377 Money Receipt
        </a>
    </div>

    <div class="col-md-6">
        <a href="/employee/attendance"
           class="btn btn-outline-success btn-custom shadow-sm w-100">
           <i class="bi bi-receipt"></i> Employee Attendance
        </a>
    </div>

    <div class="col-md-6">
        <a href="/student/attandance/list"
           class="btn btn-outline-dark btn-custom shadow-sm w-100">
           <i class="bi bi-receipt"></i> Student Attendance
        </a>
    </div>
    <% if(status === 'enabled') { %>
    <div class="col-md-6">
        <a href="/income"
           class="btn btn-outline-primary btn-custom shadow-sm w-100">
           &#8377 Others Income
        </a>
    </div>
    <% } %>

    <div class="col-md-6">
        <a href="/expence"
           class="btn btn-outline-dark btn-custom shadow-sm w-100">
           &#8377 Expenses
        </a>
    </div>
    <div class="col-md-6">
        <a href="/track/attendance"
           class="btn btn-outline-dark btn-custom shadow-sm w-100">
           <i class="bi bi-receipt"></i> Track Attendance
        </a>
    </div>
    <div class="col-md-6">
        <a href="/profit"
           class="btn btn-outline-danger btn-custom shadow-sm w-100">
            &#8377 Track Profit
        </a>
    </div>
    <div class="col-md-6">
        <a href="/payment/bill"
           class="btn btn-outline-primary btn-custom shadow-sm w-100" data-bs-toggle="modal" data-bs-target="#exampleModal1">
            &#x1F9FE MR Details 
        </a>
    </div>
    <div class="col-md-6">
        <a href="/expence/bill"
           class="btn btn-outline-primary btn-custom shadow-sm w-100" data-bs-toggle="modal" data-bs-target="#exampleModal2">
            &#x1F9FE Expenses Details
        </a>
    </div>
</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<footer class="text-center text-muted py-3">
    © 2026 Progyan Education | All Rights Reserved
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html