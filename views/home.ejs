<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progyan Education & Classic Computer Training Centre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #e3f2fd, #ffffff);
        }

        .navbar-custom {
            background: linear-gradient(135deg, #0d6efd, #4dabf7);
        }

        .card-custom {
            transition: 0.3s;
        }

        .btn-custom {
            border-radius: 25px;
            padding: 10px 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-custom:hover {
            transform: scale(1.05);
        }

        .section-title {
            font-weight: bold;
            color: #0d6efd;
            letter-spacing: 1px;
        }

        .info-text {
            font-size: 15px;
        }

        .icon-box {
            font-size: 22px;
            margin-right: 8px;
        }
    </style>
</head>

<body>
<div class="navbar-custom text-white py-3 shadow">
    <div class="container d-flex justify-content-between align-items-center">
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-mortarboard-fill"></i> Progyan Education
        </h4>
        <a href="/logout" class="btn btn-light btn-sm fw-bold">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>
</div>

<div class="container my-5 border-0">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card card-custom p-4 border-0">
                <div class="row align-items-center">

                    <div class="col-md-6 mb-4 mb-md-0">
                        <h5 class="section-title mb-3">
                            <i class="bi bi-building"></i> Institute Details
                        </h5>

                        <p class="info-text">
                            <i class="bi bi-geo-alt-fill icon-box text-danger"></i>
                            <strong>Address:</strong> 2/80 Dum Dum Road, Kolkata - 700074
                        </p>

                        <p class="info-text">
                            <i class="bi bi-telephone-fill icon-box text-success"></i>
                            <strong>Phone:</strong> +91 9123978181, +91 9007181202
                        </p>

                        <p class="info-text">
                            <i class="bi bi-info-circle-fill icon-box text-primary"></i>
                            Welcome to the admin dashboard of Progyan Education.
                        </p>
                    </div>

                    
                    <div class="col-md-6 text-center">
                        <h5 class="section-title mb-4">
                            <i class="bi bi-gear-fill"></i> Management
                        </h5>

                        <div class="d-grid gap-3">

                            <a href="/admin/admission"
                               class="btn btn-outline-primary btn-custom shadow-sm">
                               <i class="bi bi-person-plus-fill"></i> Admission
                            </a>

                            <a href="/student/payment"
                               class="btn btn-outline-danger btn-custom shadow-sm">
                               &#8377 Money Receipt
                            </a>
                             <a href="/employee/attendance"
                               class="btn btn-outline-success btn-custom shadow-sm">
                               <i class="bi bi-receipt"></i> Employee Attandance
                            </a>

                            <a href="/student/attandance/list"
                               class="btn btn-outline-dark btn-custom shadow-sm">
                               <i class="bi bi-receipt"></i> Attandance
                            </a>
                            <a href="/income"
                               class="btn btn-outline-primary btn-custom shadow-sm">
                               <i class="bi bi-receipt"></i> Income from Service
                            </a>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
<footer class="text-center text-muted py-3">
    © 2026 Progyan Education | All Rights Reserved
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html