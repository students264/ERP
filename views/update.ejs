<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Update Admission Record</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">Admission Management</a>

            <div class="d-flex gap-3">
                <a href="/" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a href="/logout" class="btn btn-light btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
    </nav>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
      <div class="card border shadow-sm">
        <div class="card-header bg-white border-bottom text-center">
          <h5 class="mb-0 fw-semibold">Update Admission Record</h5>
        </div>
        <div class="card-body">
          <form action="/student/update" method="POST">
  <input type="hidden" name="id" value="<%= data._id %>">
  <input type="hidden" name="s_name" value="<%= data.s_name %>">

  <div class="mb-3">
    <label class="form-label small fw-semibold">Date</label>
    <input type="date" name="date" class="form-control"
           value="<%= data.Date ? new Date(data.Date).toISOString().split('T')[0] : '' %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label small fw-semibold">Address</label>
    <input type="text" name="address" class="form-control" value = "<%= data.Address %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label small fw-semibold">phone No:</label>
    <input type="text" name="mobile" class="form-control" value = "<%= data.Mobile %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label small fw-semibold">Education type</label>

    <select name="type" id="type" class="form-control" required onchange="updateType()">
        <option><%= data.type %></option>
        <option value="Course" <%= data.type === 'Course' ? 'selected' : '' %>>
            Course
        </option>

        <option value="Coaching" <%= data.type === 'Coaching' ? 'selected' : '' %>>
            Coaching
        </option>

    </select>
</div>

<!-- Coaching Section -->
<div class="mb-3" id="one" style="display:none;">
    <label class="form-label small fw-semibold">Educational_Service</label>

    <select id="coaching" name="Educational_Service" class="form-control">
        <option value="<%= data.Educational_Service %>">
            <%= data.Educational_Service %>
        </option>

        <option value="class iii">class iii</option>
        <option value="class iv">class iv</option>
        <option value="class v">class v</option>
        <option value="class vi">class vi</option>
        <option value="class vii">class vii</option>
        <option value="class viii">class viii</option>
        <option value="class ix">class ix</option>
        <option value="class x">class x</option>
        <option value="class xi">class xi</option>
    </select>
</div>

<div class="mb-3" id="two" style="display:none;">
    <label class="form-label small fw-semibold">Course</label>
<select id="course" name="Educational_Service" class="form-control">
     <option value="<%= data.Educational_Service %>">
            <%= data.Educational_Service %>
        </option>
     <option value="MS-OFFICE" <%= data.Educational_Service === 'MS-OFFICE' ? 'selected' : '' %>>MS-OFFICE</option>

    <option value="TALLY" <%= data.Educational_Service === 'TALLY' ? 'selected' : '' %>>TALLY</option>

    <option value="GST" <%= data.Educational_Service === 'GST' ? 'selected' : '' %>>GST</option>

    <option value="TDS" <%= data.Educational_Service === 'TDS' ? 'selected' : '' %>>TDS</option>

    <option value="INCOME TAX" <%= data.Educational_Service === 'INCOME TAX' ? 'selected' : '' %>>INCOME TAX</option>

    <option value="ADV.EXCEL" <%= data.Educational_Service === 'ADV.EXCEL' ? 'selected' : '' %>>ADV.EXCEL</option>

    <option value="DTP" <%= data.Educational_Service === 'DTP' ? 'selected' : '' %>>DTP</option>

    <option value="GRAPHIC DESIGN" <%= data.Educational_Service === 'GRAPHIC DESIGN' ? 'selected' : '' %>>GRAPHIC DESIGN</option>

    <option value="INTERNET" <%= data.Educational_Service === 'INTERNET' ? 'selected' : '' %>>INTERNET</option>

    <option value="AUDIO & VIDEO EDITING" <%= data.Educational_Service === 'AUDIO & VIDEO EDITING' ? 'selected' : '' %>>AUDIO & VIDEO EDITING</option>

    <option value="C++" <%= data.Educational_Service === 'C++' ? 'selected' : '' %>>C++</option>

    <option value="JAVA(B)" <%= data.Educational_Service === 'JAVA(B)' ? 'selected' : '' %>>JAVA(B)</option>

    <option value="PYTHON" <%= data.Educational_Service === 'PYTHON' ? 'selected' : '' %>>PYTHON</option>

    <option value="HTML" <%= data.Educational_Service === 'HTML' ? 'selected' : '' %>>HTML</option>

    <option value="Q BASIC" <%= data.Educational_Service === 'Q BASIC' ? 'selected' : '' %>>Q BASIC</option>

    <option value="GW BASIC" <%= data.Educational_Service === 'GW BASIC' ? 'selected' : '' %>>GW BASIC</option>

    <option value="SMALL BASIC" <%= data.Educational_Service === 'SMALL BASIC' ? 'selected' : '' %>>SMALL BASIC</option>

    <option value="WEB DESIGN" <%= data.Educational_Service === 'WEB DESIGN' ? 'selected' : '' %>>WEB DESIGN</option>

    <option value="ORACLE" <%= data.Educational_Service === 'ORACLE' ? 'selected' : '' %>>ORACLE</option>

    <option value="WEB DEVELOPMENT" <%= data.Educational_Service === 'WEB DEVELOPMENT' ? 'selected' : '' %>>WEB DEVELOPMENT</option>

    <option value="ENG. TYPING" <%= data.Educational_Service === 'ENG. TYPING' ? 'selected' : '' %>>ENG. TYPING</option>

    <option value="SCHOOL COURSE" <%= data.Educational_Service === 'SCHOOL COURSE' ? 'selected' : '' %>>SCHOOL COURSE</option>

    <option value="BENG. TYPING" <%= data.Educational_Service === 'BENG. TYPING' ? 'selected' : '' %>>BENG. TYPING</option>

    <option value="SPOKEN ENGLISH" <%= data.Educational_Service === 'SPOKEN ENGLISH' ? 'selected' : '' %>>SPOKEN ENGLISH</option>

    <option value="DIGITAL MARKERING" <%= data.Educational_Service === 'DIGITAL MARKERING' ? 'selected' : '' %>>DIGITAL MARKERING</option>
    </select>
</div>
<div class="mb-3" id="three" style="display:none;">
    <label class="form-label small fw-semibold">Board</label>
   <select id="board" name="board" class="form-control">
    <option value="<%= data.board ? data.board : '--' %>">
        <%= data.board ? data.board : "--" %>
    </option>
    <option value="CBSE">CBSE</option>
    <option value="ICSE">ICSE</option>
</select>
</div>
  <div class="mb-4">
  <label class="form-label small fw-semibold">Month</label>

  <select name="month" class="form-control" required>
    <option><%= data.Month %></option>

    <option value="January" <%= data.month === 'January' ? 'selected' : '' %>>January</option>
    <option value="February" <%= data.month === 'February' ? 'selected' : '' %>>February</option>
    <option value="March" <%= data.month === 'March' ? 'selected' : '' %>>March</option>
    <option value="April" <%= data.month === 'April' ? 'selected' : '' %>>April</option>
    <option value="May" <%= data.month === 'May' ? 'selected' : '' %>>May</option>
    <option value="June" <%= data.month === 'June' ? 'selected' : '' %>>June</option>
    <option value="July" <%= data.month === 'July' ? 'selected' : '' %>>July</option>
    <option value="August" <%= data.month === 'August' ? 'selected' : '' %>>August</option>
    <option value="September" <%= data.month === 'September' ? 'selected' : '' %>>September</option>
    <option value="October" <%= data.month === 'October' ? 'selected' : '' %>>October</option>
    <option value="November" <%= data.month === 'November' ? 'selected' : '' %>>November</option>
    <option value="December" <%= data.month === 'December' ? 'selected' : '' %>>December</option>
  </select>
</div>
  <div class="d-grid">
    <button type="submit" class="btn btn-primary fw-semibold rounded-pill">
      Update Record
    </button>
  </div>

</form>
        </div>
      </div>
    </div>
  </div>
</div>
<script>

function updateType() {

    let type = document.getElementById("type").value;

    let coaching = document.getElementById("coaching");
    let course = document.getElementById("course");

    if(type === "Coaching") {

        document.getElementById("one").style.display = "block";
        document.getElementById("three").style.display = "block";
        document.getElementById("two").style.display = "none";

        coaching.disabled = false;
        course.disabled = true;

    } else {

        document.getElementById("two").style.display = "block";
        document.getElementById("one").style.display = "none";
        document.getElementById("three").style.display = "none";

        coaching.disabled = true;
        course.disabled = false;
    }
}

window.onload = updateType;

</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>